<?xml version='1.0' encoding='windows-1252'?>
<!--
  WiX 3 source for the Synbad MSI.

  We ship a per-user installer (no UAC prompt) that mirrors what
  `install.ps1` does manually:
    - Drop `synbadd.exe` and `synbad-gui.exe` under %LOCALAPPDATA%\Programs\Synbad
    - Add a Start Menu shortcut to the GUI
    - Register `synbadd` for login autostart via HKCU\…\Run

  Why per-user: `synbadd` needs the user's graphical session. A per-machine
  install (running as SYSTEM via Task Scheduler) can't share input with the
  logged-in user reliably; this matches the rationale in dist/README.md.

  Built by `cargo-wix` in the release pipeline. cargo-wix passes the build
  target directory in via `-d TargetDir=…` and the version via `-d Version=…`.
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
      Id='*'
      Name='Synbad'
      UpgradeCode='D7C3AED0-2563-4EB0-8C3A-7C3AED2563EB'
      Manufacturer='Synbad Contributors'
      Language='1033'
      Codepage='1252'
      Version='$(var.Version)'>

    <Package
        Id='*'
        Keywords='Installer'
        Description='Synbad — keyboard, mouse, and clipboard sharing'
        Manufacturer='Synbad Contributors'
        InstallerVersion='500'
        Languages='1033'
        Compressed='yes'
        InstallScope='perUser'
        SummaryCodepage='1252'/>

    <MajorUpgrade
        Schedule='afterInstallInitialize'
        DowngradeErrorMessage='A newer version of Synbad is already installed.'/>

    <Media Id='1' Cabinet='synbad.cab' EmbedCab='yes'/>

    <Property Id='ALLUSERS' Value='2'/>
    <Property Id='MSIINSTALLPERUSER' Value='1'/>
    <Property Id='ARPPRODUCTICON' Value='SynbadIcon.exe'/>

    <Icon Id='SynbadIcon.exe' SourceFile='$(var.IconPath)'/>

    <!-- Per-user installs (HKCU) trip two WiX ICE checks unless we handle
         them deliberately:
           ICE38 — every component under the user profile must use an HKCU
                   RegistryValue as its KeyPath, not a File. We add a tiny
                   `Software\Synbad\Components\<name>` flag per component for
                   exactly that purpose.
           ICE64 — every directory under the user profile must show up in
                   the RemoveFile/RemoveFolder table. The `CleanupInstallDir`
                   component below carries the RemoveFolder entries for the
                   install dir + its parent. -->
    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='LocalAppDataFolder'>
        <Directory Id='ProgramsFolder' Name='Programs'>
          <Directory Id='INSTALLDIR' Name='Synbad'>
            <!-- File+Registry-keypath components need explicit, stable GUIDs
                 (WiX 3 CNDL0230); '*' auto-gen only works for single-keypath
                 components. Generated once with uuidgen; never change these
                 across versions or upgrades break. -->
            <Component Id='SynbaddExe' Guid='9B86752F-D81D-4D1B-A9A4-D82C422B3B11'>
              <File
                  Id='SynbaddExe'
                  Name='synbadd.exe'
                  Source='$(var.TargetDir)\synbadd.exe'/>
              <RegistryValue
                  Root='HKCU'
                  Key='Software\Synbad\Components'
                  Name='SynbaddExe'
                  Type='integer'
                  Value='1'
                  KeyPath='yes'/>
              <!-- Autostart the daemon at login. Per-user Run key — no admin
                   needed and no scheduled-task custom action required. -->
              <RegistryValue
                  Root='HKCU'
                  Key='Software\Microsoft\Windows\CurrentVersion\Run'
                  Name='SynbadDaemon'
                  Type='string'
                  Value='"[INSTALLDIR]synbadd.exe"'/>
            </Component>

            <Component Id='SynbadGuiExe' Guid='A761E683-48A7-494E-8C37-5ABEE613D4D8'>
              <File
                  Id='SynbadGuiExe'
                  Name='synbad-gui.exe'
                  Source='$(var.TargetDir)\synbad-gui.exe'/>
              <RegistryValue
                  Root='HKCU'
                  Key='Software\Synbad\Components'
                  Name='SynbadGuiExe'
                  Type='integer'
                  Value='1'
                  KeyPath='yes'/>
            </Component>

            <Component Id='LicenseFile' Guid='E1EC2720-B994-4072-B31E-AADEE75D9557'>
              <File Id='LicenseFile' Name='LICENSE.txt' Source='$(var.LicensePath)'/>
              <RegistryValue
                  Root='HKCU'
                  Key='Software\Synbad\Components'
                  Name='LicenseFile'
                  Type='integer'
                  Value='1'
                  KeyPath='yes'/>
            </Component>

            <Component Id='CleanupInstallDir' Guid='*'>
              <RegistryValue
                  Root='HKCU'
                  Key='Software\Synbad\Components'
                  Name='CleanupInstallDir'
                  Type='integer'
                  Value='1'
                  KeyPath='yes'/>
              <!-- RemoveFolder runs at uninstall and only removes empty
                   directories, so the Programs entry is safe even when
                   other apps share %LOCALAPPDATA%\Programs. -->
              <RemoveFolder Id='RemoveInstallDir' On='uninstall'/>
              <RemoveFolder Id='RemoveProgramsFolder' Directory='ProgramsFolder' On='uninstall'/>
            </Component>
          </Directory>
        </Directory>
      </Directory>

      <Directory Id='ProgramMenuFolder'>
        <Directory Id='ApplicationProgramsFolder' Name='Synbad'>
          <Component Id='ApplicationShortcut' Guid='*'>
            <Shortcut
                Id='GuiShortcut'
                Name='Synbad'
                Description='Launch the Synbad GUI'
                Target='[INSTALLDIR]synbad-gui.exe'
                WorkingDirectory='INSTALLDIR'
                Icon='SynbadIcon.exe'/>
            <RemoveFolder Id='RemoveAppShortcutFolder' On='uninstall'/>
            <RegistryValue
                Root='HKCU'
                Key='Software\Synbad'
                Name='installed'
                Type='integer'
                Value='1'
                KeyPath='yes'/>
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <Feature Id='Complete' Title='Synbad' Level='1'>
      <ComponentRef Id='SynbaddExe'/>
      <ComponentRef Id='SynbadGuiExe'/>
      <ComponentRef Id='LicenseFile'/>
      <ComponentRef Id='CleanupInstallDir'/>
      <ComponentRef Id='ApplicationShortcut'/>
    </Feature>
  </Product>
</Wix>
